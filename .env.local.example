# Copy to `.env.local` (gitignored) and fill in.
# `.env.local` is read automatically by Next.js in dev and by Vercel in preview/prod.

# Google Maps JavaScript API key (browser-restricted).
# Enables address autocomplete on the incorporation wizard. The wizard falls
# back to plain text inputs if this is unset.
#
# Setup:
#   1. Google Cloud Console -> create/select project
#   2. APIs & Services -> enable "Maps JavaScript API" and "Places API"
#   3. Credentials -> Create API key
#   4. Edit the key:
#      - Application restrictions: HTTP referrers (web sites)
#        Allow: http://localhost:3000/*, https://*.vercel.app/*,
#               https://korporex.ca/*
#      - API restrictions: restrict to Maps JavaScript API + Places API
#   5. Paste the key below.
#
# Because this key is prefixed with NEXT_PUBLIC_ it is exposed to the client.
# HTTP-referrer + API restrictions are what keep it safe — do not skip them.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Brevo Transactional Email API key (server-side only — must NOT be NEXT_PUBLIC_).
# Used by `src/app/api/contact/route.ts` (contact + hero forms) and
# `src/app/api/incorporate/route.ts` (wizard order intake) to email submissions
# to contact@korporex.ca. Without this key, both routes log submissions to the
# console and return a success response so local dev isn't blocked — but no
# email is actually sent.
#
# Setup:
#   1. Brevo dashboard -> SMTP & API -> "API keys & MCP" tab
#   2. Click "Generate a new API key" -> name it e.g. "korporex-contact-form"
#   3. Copy the key (shown only once) and paste below
#   4. In Vercel: Settings -> Environment Variables -> add BREVO_API_KEY for
#      Production, Preview, and Development, then redeploy
#
# This is a SEPARATE key from the SMTP key used by Gmail "Send mail as".
BREVO_API_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
#
# Used by `src/app/api/incorporate/route.ts` to create a Stripe Checkout Session
# and by `src/app/api/stripe-webhook/route.ts` to verify incoming webhook events.
# Without STRIPE_SECRET_KEY, /api/incorporate falls back to redirecting
# straight to the confirmation page with a dev ref — so local dev is unblocked.
#
# Test mode first:
#   Stripe Dashboard -> toggle "Test mode" (top-right) -> Developers -> API keys
#   Copy the Secret key (sk_test_...) into STRIPE_SECRET_KEY
#   Copy the Publishable key (pk_test_...) into NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
#   Use card 4242 4242 4242 4242 with any future expiry + any CVC to test.
#
# Going live: switch Dashboard toggle off, copy sk_live_.../pk_live_... keys.
# Rotate/store separately in Vercel (Production vs Preview vs Development).
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook signing secret — used to verify Stripe calls to /api/stripe-webhook.
#
# Local dev: `stripe listen --forward-to localhost:3000/api/stripe-webhook`
#   The CLI prints a whsec_... value; paste it here. Keep that terminal open
#   while testing so events are forwarded to your local route.
#
# Production: Stripe Dashboard -> Developers -> Webhooks -> Add endpoint
#   URL: https://<your-domain>/api/stripe-webhook
#   Events: checkout.session.completed,
#           checkout.session.async_payment_succeeded,
#           checkout.session.async_payment_failed
#   Copy the endpoint's "Signing secret" (whsec_...) into Vercel env vars.
STRIPE_WEBHOOK_SECRET=

# Absolute site origin used to build Stripe success_url / cancel_url.
# Local: http://localhost:3000
# Preview/Prod: Vercel auto-provides VERCEL_URL as a fallback, but setting
# this explicitly is more reliable (e.g. set to https://korporex.ca on Vercel).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Owner login (/admin → /dashboard) ───────────────────────────────────────
#
# Single-owner credentials gate for /dashboard. The login flow:
#   1. Visitor submits {username, password} to /api/auth/login
#   2. Route compares both credentials in constant time; on success, signs a
#      JWT with ADMIN_SESSION_SECRET (HS256), 7-day expiry
#   3. JWT is stored in an HttpOnly Secure SameSite=Lax cookie
#   4. Middleware checks the cookie on every /dashboard/* request; missing or
#      invalid cookies redirect to /login.
#
# All three vars are server-side only (do NOT prefix with NEXT_PUBLIC_).
#
# ADMIN_USERNAME: the owner username. Compared case-insensitively.
# ADMIN_PASSWORD: plaintext. Rotate by changing this value (+ Vercel env var)
#   and redeploying — existing sessions remain valid until their JWT expires
#   (or until ADMIN_SESSION_SECRET is rotated).
# ADMIN_SESSION_SECRET: 32+ bytes (we use 32 random bytes hex-encoded = 64
#   chars). Regenerate with: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`.
#   Rotating this secret invalidates every active session immediately.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# ─── Supabase (server-state for SEO Dashboard Phase 2+) ──────────────────────
#
# Free-tier Supabase project, created directly at supabase.com (NOT via Vercel
# Marketplace). The Vercel Marketplace path attaches the project to Hadri Law's
# existing Pro org and triggers a ~$10/mo additional-project charge; going
# direct keeps it on the free tier ($0/mo, 500MB DB, 2 free projects allowed).
#
# Why a separate org from Hadri:
#   - Project isolation rule in CLAUDE.md ("Each project is completely separate
#     and independent from others, including hadrilaw.com").
#   - Compliance — Hadri's DB holds privileged law-firm client data; mixing
#     Korporex operational data with it risks solicitor-client privilege +
#     PIPEDA purpose-limitation issues.
#   - Korporex's "not a law firm" framing demands clean separation.
#
# Setup:
#   1. supabase.com/dashboard -> top-left org dropdown -> "New organization"
#   2. Plan: Free (do NOT pick Pro)
#   3. Create project "korporex" inside the new free org
#   4. Settings -> API: copy Project URL, anon public key, service_role secret
#   5. Paste below and into Vercel: Settings -> Environment Variables. The two
#      NEXT_PUBLIC_* vars must be added to Production + Preview + Development;
#      SUPABASE_SERVICE_ROLE_KEY is server-side only, do NOT expose it.
#
# NEXT_PUBLIC_SUPABASE_URL: project's REST endpoint, safe to expose.
# NEXT_PUBLIC_SUPABASE_ANON_KEY: public anon JWT, safe to expose; works only
#   for tables/operations allowed by Row Level Security policies.
# SUPABASE_SERVICE_ROLE_KEY: bypasses RLS; server-side use ONLY (route handlers,
#   server components). NEVER prefix with NEXT_PUBLIC_, never log it. Rotate by
#   regenerating the JWT secret in Supabase -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
